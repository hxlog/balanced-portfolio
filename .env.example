# =====================================================================
# Balanced Portfolio - 环境变量模板
# 复制为 .env 后按需修改; .env 不会进 git。生产必填项见各分组标注。
# 说明: 非必填项留空时使用代码默认值；标注必填的项不能为空。
# =====================================================================

# ===== PostgreSQL =====
PGHOST=127.0.0.1              # 数据库主机; 远程部署时改为实际内网地址
PGPORT=5432                   # 端口
PGDATABASE=balanced_portfolio # 建议使用独立业务库
PGUSER=postgres               # 用户
PGPASSWORD=                   # 【必填】数据库密码
PG_CONNECT_TIMEOUT=15         # 连接超时(秒)

# ===== 行情 ingest (bp_ingest) =====
BP_DEFAULT_START_DATE=2017-01-01  # 首拉行情起始日(无历史的标的从此日开始)
BP_REVISION_DAYS=7                # 增量回看修正天数(覆盖最近 N 天以修订数据)
BP_LAG_DAYS=0                     # 只拉到 T-N 个交易日(默认 T+0, 收盘后立即可用)
BP_MAX_RETRIES=3                  # akshare 抓取失败重试次数(单标的 tenacity 重试)
BP_REQUEST_INTERVAL=2.5           # 标的间抓取间隔基数(秒); 服务器慢落库建议 5-10
BP_REQUEST_JITTER=3.5             # 标的间随机抖动上限(秒); 实际间隔 = INTERVAL + uniform(0,JITTER)
BP_HTTP_RETRY=4                   # HTTP 单请求重试次数(连接级+429/503, 分级退避)
BP_EM_COOKIE=""                   # 东财 cookie(quote.eastmoney.com 完整 Cookie 串; 必须用双引号包裹; 含 ct/ut 即可; 比无 JS 预热更有效)
BP_SINA_COOKIE=""                 # 新浪 cookie(finance.sina.com.cn 完整 Cookie 串; 双引号包裹; 无则留空靠预热)
BP_COOKIE_REFRESH_MIN=15          # cookie 预热刷新间隔(分钟)
BP_SCHEDULE_HOURS=6               # 调度器增量更新间隔(小时); 收盘后追最新交易日可设 1
BP_CFFEX_SYNC_HOURS=2             # CFFEX 日行情增量同步间隔(小时); 有新交易日则落库, 否则跳过
BP_LOG_LEVEL=INFO                 # 日志级别 DEBUG/INFO/WARNING/ERROR

# ===== API / 量化引擎 (bp_api) =====
BP_TRADING_DAYS=244           # 年化所用交易日数(夏普/波动率年化)
BP_MIN_WINDOW=60              # 最小可优化历史窗口(交易日); 不足则该标的暂不纳入
BP_OPT_MAXITER=200            # SLSQP(最大夏普/Sortino) 最大迭代
BP_OPT_FTOL=1e-8              # SLSQP 收敛精度
# 以下三项为"全局兜底默认"，当前实际由各组合自身参数覆盖(创建时设定)，一般无需改:
BP_RISK_FREE=0               # 无风险利率全局兜底(组合级 risk_free_rate 优先)
BP_DEFAULT_LOOKBACK=156      # 回溯窗口全局兜底(组合级 lookback_days 优先)
BP_REBALANCE_BAND=0.05       # 再平衡偏离带全局兜底(组合级 rebalance_band 优先)

# ===== 任务队列 / 并行 (Celery + Redis) =====
REDIS_URL=redis://127.0.0.1:6379/0          # Redis 地址(缓存 + 限流 + Celery)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0  # Celery broker(默认=REDIS_URL)
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0  # Celery 结果后端(默认=REDIS_URL)
BP_TASK_MODE=celery          # celery=走队列; inline=直接用 FastAPI BackgroundTasks(无 Redis 时降级)
BP_CELERY_CONCURRENCY=2      # worker 并发任务数(弱机设 1)
BP_BACKTEST_METHOD_WORKERS=2 # 单组合内 4 种方法的并行数(弱机/容器设 1; Celery 守护进程内自动回退线程池)
BP_MAX_CPU_FRACTION=0.75     # 自动推导并行 worker 时最多占用的 CPU 核心预算占比

# ===== 鉴权 / 安全 =====
BP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000  # 逗号分隔; 生产改为实际 HTTPS 域名
BP_JWT_SECRET=                               # 【必填】JWT 签名密钥; 至少 32 字符
BP_JWT_EXPIRE_HOURS=168                       # 登录 token 有效期(小时); 与 BP_SESSION_MAX_AGE_DAYS 对齐
BP_SESSION_MAX_AGE_DAYS=7                     # 前端 httpOnly Cookie 会话天数(与 JWT 有效期一致)
BP_ADMIN_EMAIL=admin@example.com              # 超级管理员邮箱; 首次启动前改为真实地址
BP_ADMIN_INITIAL_PASSWORD=                    # 首次创建管理员时必填; 至少 12 字符，创建后可移除
# 人机验证已改为 TOTP 两步验证(管理员强制、全员可自助开启)，无需任何境外服务。

# ===== 前端 (Next.js rewrites, PM2 web 进程读取) =====
BP_API_BASE=http://127.0.0.1:8000  # 前端 /api 代理指向的后端地址
BP_SITE_URL=http://localhost:3000   # 站点公开 URL; 用于 canonical/分享元数据
